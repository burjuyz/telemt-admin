# Пример конфигурации для Docker.
# Скопируйте в config/telemt-admin.toml и укажите bot_token, admin_ids, при необходимости auth_header для control API.

bot_token = "УКАЖИТЕ_ТОКЕН_ОТ_BOTFATHER"
admin_ids = [123456789]

# Режим external и метка для UI задаются в docker-compose.yml (TELEMT_ADMIN__RUNTIME__*).

db_path = "/var/lib/telemt-admin/state.db"
telemt_config_path = "/etc/telemt.toml"

[telemt_api]
enabled = true
base_url = "http://telemt:9091"
# auth_header = "Bearer ..."  # при необходимости; иначе можно через TELEMT_ADMIN__TELEMT_API__AUTH_HEADER в .env
timeout_ms = 5000
allow_file_fallback = false
prefer_api_links = true

[notifications]
enabled = true
health_check_interval_secs = 60
notify_on_health_change = true
notify_on_runtime_alerts = true
notify_on_new_request = true

[security]
default_token_days = 14
max_token_days = 180
allow_auto_approve_tokens = true
