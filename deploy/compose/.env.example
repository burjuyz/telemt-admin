# Тег образа: ghcr.io/fgbm/telemt-admin:<версия>
TELEMT_ADMIN_VERSION=latest

# Уровень логов (tracing). Для отладки: debug или telemt_admin=debug
RUST_LOG=info

# Секреты (bot_token, telemt_api.auth_header) задавайте в config/telemt-admin.toml.
# Через env — только если нужно переопределить без правки файла:
# TELEMT_ADMIN__BOT_TOKEN=
# TELEMT_ADMIN__TELEMT_API__AUTH_HEADER=

# Если из контейнера недоступен api.telegram.org, укажите username бота без @:
# TELEMT_ADMIN__BOT_USERNAME=MyBot
# TELOXIDE_TOKEN=

# Опциональные overrides поверх config/telemt-admin.toml:
# TELEMT_ADMIN__TELEMT_API__BASE_URL=http://telemt:9091
# TELEMT_ADMIN__ADMIN_IDS=123456789
