# Образ из GHCR. Для pinning можно указать конкретную версию вместо latest.
TELEMT_ADMIN_IMAGE=ghcr.io/fgbm/telemt-admin:latest

# Секреты и docker-specific overrides.
# Можно использовать либо TELEMT_ADMIN__BOT_TOKEN, либо TELOXIDE_TOKEN.
TELEMT_ADMIN__BOT_TOKEN=
# TELOXIDE_TOKEN=
TELEMT_ADMIN__TELEMT_API__AUTH_HEADER=

# Опциональные overrides поверх config/telemt-admin.toml:
# TELEMT_ADMIN__TELEMT_API__BASE_URL=http://telemt:9091
# TELEMT_ADMIN__ADMIN_IDS=123456789
